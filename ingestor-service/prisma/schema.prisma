generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Our main "Error Log" table
model Log {
  id          String   @id @default(uuid())
  project     String
  level       String
  message     String
  stack       String?  // For error details
  meta        Json?    // Flexible data field
  count       Int      @default(1)
  
  // YENİ ALAN: AI analizini burada tutacağız
  // @db.Text kullanıyoruz çünkü AI cevabı uzun olabilir, standart String yetmeyebilir.
  aiAnalysis  String?  @db.Text 

  timestamp   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Proje, hata seviyesi ve mesaj aynıysa, 
  // Prisma bunu 'aynı kayıt' olarak kabul edecek (Upsert için kritik).
  @@unique([project, level, message])
}