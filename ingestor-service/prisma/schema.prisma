generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Our main "Error Log" table
model Log {
  id        String   @id @default(uuid())
  project   String
  level     String
  message   String
  stack     String?  // For error details
  meta      Json?    // <-- ADDED: Flexible data field
  count     Int      @default(1)
  timestamp DateTime @default(now())
  updatedAt DateTime @updatedAt
}